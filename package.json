{
  "name": "uvu1.me-v2",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "bun run generate:contents && vite dev --port 3000",
    "build": "bun run generate:contents && vite build",
    "preview": "vite preview",
    "test": "vitest --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts",
    "lint": "eslint",
    "format": "prettier --write . && eslint --fix",
    "check": "prettier --check .",
    "deploy": "bun run build && wrangler deploy",
    "generate:thumbs": "bun run scripts/generate-thumbnails.tsx",
    "generate:projects": "bun run scripts/generate-projects.tsx",
    "generate:sitemap": "bun run scripts/generate-sitemap.tsx",
    "generate:robots": "bun run scripts/generate-robots.tsx",
    "generate:rss": "bun run scripts/generate-rss.tsx",
    "generate:contents": "bun run scripts/generate-thumbnails.tsx && bun run scripts/generate-projects.tsx && bun run scripts/generate-rss.tsx && bun run scripts/generate-sitemap.tsx && bun run scripts/generate-robots.tsx"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.26.0",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.545.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "satori": "^0.26.0",
    "shiki": "^4.1.0",
    "tailwindcss": "^4.3.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/eslint-config": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.20.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.7",
    "wrangler": "^4.70.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
