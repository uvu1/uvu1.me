{
  "name": "uvu1.me-v2",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "bun run generate:contents && vite dev --port 3000",
    "build": "bun run generate:contents && vite build",
    "preview": "vite preview",
    "test": "vitest --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts",
    "lint": "eslint",
    "format": "prettier --write . && eslint --fix",
    "check": "prettier --check .",
    "ci": "bun run check && bun run lint && bun run test:run && bun run build",
    "deploy": "wrangler deploy",
    "generate:thumbs": "bun run scripts/generate-thumbnails.tsx",
    "generate:projects": "bun run scripts/generate-projects.tsx",
    "generate:sitemap": "bun run scripts/generate-sitemap.tsx",
    "generate:robots": "bun run scripts/generate-robots.tsx",
    "generate:rss": "bun run scripts/generate-rss.tsx",
    "generate:favicons": "bun run scripts/generate-favicon.ts",
    "generate:contents": "bun run scripts/generate-thumbnails.tsx && bun run scripts/generate-projects.tsx && bun run scripts/generate-rss.tsx && bun run scripts/generate-sitemap.tsx && bun run scripts/generate-robots.tsx && bun run scripts/generate-favicon.ts"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "1.37.2",
    "@resvg/resvg-js": "2.6.2",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/react-router": "1.170.4",
    "@tanstack/react-router-ssr-query": "1.167.0",
    "@tanstack/react-start": "1.168.6",
    "@tanstack/router-plugin": "1.168.6",
    "gray-matter": "4.0.3",
    "lucide-react": "0.545.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-icons": "5.6.0",
    "react-markdown": "10.1.0",
    "rehype-pretty-code": "0.14.3",
    "rehype-slug": "6.0.0",
    "rehype-stringify": "10.0.1",
    "remark-gfm": "4.0.1",
    "remark-parse": "11.0.0",
    "remark-rehype": "11.1.2",
    "satori": "0.26.0",
    "shiki": "4.1.0",
    "tailwindcss": "4.3.0",
    "unified": "11.0.5",
    "unist-util-visit": "5.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260526.1",
    "@playwright/test": "1.60.0",
    "@tailwindcss/typography": "0.5.19",
    "@tanstack/devtools-vite": "0.7.0",
    "@tanstack/eslint-config": "0.4.0",
    "@tanstack/react-devtools": "0.10.5",
    "@tanstack/react-router-devtools": "1.167.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "22.19.19",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "9.39.4",
    "jsdom": "29.1.1",
    "prettier": "3.8.3",
    "sharp": "^0.34.5",
    "typescript": "6.0.3",
    "vite": "8.0.13",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.7",
    "wrangler": "4.93.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
